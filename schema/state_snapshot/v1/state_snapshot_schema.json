          "$ref": "#/$defs/camera_value_state_int32"
        }
      }
    },
    "device_camera_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "exposure",
        "focus",
        "white_balance",
        "stabilization",
        "flash_torch",
        "zoom_crop",
        "processing",
        "metering",
        "antibanding",
        "orientation_mirroring",
        "privacy_hardware_block"
      ],
      "properties": {
