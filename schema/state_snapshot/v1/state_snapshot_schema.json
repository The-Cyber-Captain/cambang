    "camera_value_state_string": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "support",
        "has_target",
        "target",
        "has_applied",
        "applied",
        "apply_status",
        "apply_error_code"
      ],
      "properties": {
        "support": {
          "$ref": "#/$defs/camera_value_support"
        },
        "has_target": {
          "type": "boolean"
        },
        "target": {
          "type": "string"
        },
        "has_applied": {
