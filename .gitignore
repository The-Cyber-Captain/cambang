# ==============================================================================
# CamBANG — repo root .gitignore
#
# Philosophy:
# - Root ignores cover: IDE noise, host OS cruft, build system output, and
#   third-party build products.
# - Each Godot project (tests/, demos/, samples/) should have its own .gitignore
#   for .godot/, .import/, export presets, and per-project bin/ outputs.
#   (Avoid sprinkling tests/** rules into the root.)
# ==============================================================================

# ------------------------------------------------------------------------------
# JetBrains / CLion
# ------------------------------------------------------------------------------
.idea/
*.iml
cmake-build-*/

# Optional: CLion / CMake presets can produce these:
CMakeSettings.json

# ------------------------------------------------------------------------------
# CMake (IDE-only) // phase out
# ------------------------------------------------------------------------------
CMakeFiles/
build/
CMakeCache.txt
cmake_install.cmake
Makefile
compile_commands.json
compile_commands/

# ------------------------------------------------------------------------------
# Ninja // phase out
# ------------------------------------------------------------------------------
.ninja_deps
.ninja_log


# ------------------------------
# Python / SCons
# ------------------------------
__pycache__/
*.py[cod]
*$py.class

# ------------------------------------------------------------------------------
# SCons
# ------------------------------------------------------------------------------
.sconsign.*
.sconsign.dblite
.scons_cache/
.scons-cache/

# ------------------------------------------------------------------------------
# CamBANG build output
# ------------------------------------------------------------------------------
out/

# If you later add additional standard output roots, list them explicitly here:
# dist/
# artifacts/

# ------------------------------------------------------------------------------
# Third-party build products
# ------------------------------------------------------------------------------
# godot-cpp is a pinned submodule; we never commit its generated outputs.
thirdparty/godot-cpp/bin/
thirdparty/godot-cpp/gen/
thirdparty/godot-cpp/.sconsign.dblite

# ------------------------------------------------------------------------------
# OS / Desktop noise
# ------------------------------------------------------------------------------
# macOS
.DS_Store
# Windows
Thumbs.db
Desktop.ini

# ------------------------------------------------------------------------------
# Compiled binaries / objects (safety net)
# ------------------------------------------------------------------------------
# We generally do not commit built artifacts to the repo. If a future demo/harness
# legitimately needs checked-in binaries, add a narrow "!" exception locally.
*.exe
*.dll
*.so
*.dylib
*.a
*.lib
*.pdb
*.obj
*.o
*.ilk
*.exp

# ------------------------------------------------------------------------------
# Editor swap/backup files
# ------------------------------------------------------------------------------
*~
*.swp
*.swo
*.bak


# ------------------------------------------------------------------------------
# Notes
# ------------------------------------------------------------------------------
# Godot projects: place per-project ignores in:
#   tests/<godot_project>/.gitignore
#   demos/<godot_project>/.gitignore
#   samples/<godot_project>/.gitignore
# Typical Godot ignores include:
#   .godot/ .import/ export_presets.cfg export.cfg bin/*.dll bin/*.a
# plus *not* ignoring bin/*.gdextension.