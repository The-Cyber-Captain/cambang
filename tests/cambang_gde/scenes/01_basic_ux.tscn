[sub_resource type="GDScript" id="GDScript_pb52r"]
script/source = "extends Control
# NOT FOR AUTOMATED / CLI TESTING
# MANUAL, INTERACTIVE, TESTING ONLY
const WAIT_BEFORE_QUIT = 1.0
const FAKE_LOCATION := {\"latitude_degrees\": 55.9533, \"longitude_degrees\": -3.1883,}
var device_00 : CamBANGDevice 
var stream_00 : CamBANGStream 
#var capture_profile_00 : Dictionary = {
	#\"width\": 1280,
	#\"height\": 720,
	#\"format_fourcc\": 0x00000020, # use the project/provider FOURCC value you intend
	#\"still_image_bundle\": {
		#\"members\": [
			#{
				#\"image_member_index\": 0,
				#\"role\": \"DEFAULT_METERED\",
				#\"intended_exposure_compensation_milli_ev\": 0,
			#},
		#],
	#},
#}

var capture_profile_00 : Dictionary = {
	\"width\": 640,
	\"height\": 360,
	\"still_image_bundle\": {
		\"members\": [
			{
				\"image_member_index\": 0,
				\"role\": \"DEFAULT_METERED\",
				\"intended_exposure_compensation_milli_ev\": 0,
			},
		],
	},
}

var capture_profile_bun : Dictionary = {
	\"still_image_bundle\": {
		\"members\": [
		{
			\"image_member_index\": 0,
			\"role\": CamBANGCaptureResult.IMAGE_ROLE_DEFAULT_METERED,
			\"intended_exposure_compensation_milli_ev\": 0,
		},
		{
			\"image_member_index\": 1,
			\"role\": CamBANGCaptureResult.IMAGE_ROLE_ADDITIONAL_BRACKET,
			\"intended_exposure_compensation_milli_ev\": -1000,
		},
		{
			\"image_member_index\": 2,
			\"role\": CamBANGCaptureResult.IMAGE_ROLE_ADDITIONAL_BRACKET,
			\"intended_exposure_compensation_milli_ev\": 1000,
		},
	]
	},
}

func _display_path_kind_name(path_kind: int) -> String:
	match path_kind:
		CamBANGStreamResult.DISPLAY_PATH_RETAINED_GPU_BACKING:
			return \"retained_gpu_backing\"
		CamBANGStreamResult.DISPLAY_PATH_STREAM_LIVE_CPU_DISPLAY_VIEW:
			return \"stream_live_cpu_display_view\"
		_:
			return \"none\"


func _plan_posture_is_gpu(posture: String) -> bool:
	return posture.begins_with(\"GPU-primary\")

func _ready():
	CamBANGServer.set_capture_geolocation(FAKE_LOCATION)
	#CamBANGServer.
	CamBANGServer.start(CamBANGServer.PROVIDER_KIND_SYNTHETIC)
	#CamBANGServer.start(CamBANGServer.PROVIDER_KIND_PLATFORM_BACKED)
	var endpoints: Array = CamBANGServer.enumerate_devices()
	if endpoints.is_empty():
		push_error(\"KERR No CamBANG endpoints\")
		return

	var endpoint = endpoints[0]
	print(\"ENDPOINTS: \", endpoints)
	if typeof(endpoint) != TYPE_DICTIONARY:
		push_error(\"KERR Endpoint entry was not a Dictionary\")
		return

	var hardware_id: String = str(endpoint.get(\"hardware_id\", \"\"))
	if hardware_id.is_empty():
		push_error(\"KERR Endpoint had no hardware_id\")
		return
		
	device_00 = CamBANGServer.get_device_for_hardware_id(\"synthetic:0\")
	#CamBANGServer.get_device()
	#device_00 = CamBANGServer.get_device_for_hardware_id(\"\\\\\\\\?\\\\USB#VID_13D3&PID_5279&MI_00#6&f7bbb15&0&0000#{e5323777-f976-4f5b-9b55-b94699c46e44}\\\\GLOBAL\")
	
	#var device_01 : CamBANGDevice = CamBANGServer.get_device_for_hardware_id(\"synthetic:1\")
	device_00.set_still_capture_profile(capture_profile_00)

	
	device_00.engage()
	#device_01.engage()

	while not device_00.live:
		await device_00.live_changed

	#var stream_00 : CamBANGStream = device_00.create_stream()
	stream_00 = device_00.create_stream(({
	\"intent\": CamBANGStream.INTENT_VIEWFINDER,
	\"profile\": {
		\"width\": 640,
		\"height\": 360,
		\"format_fourcc\": CamBANGServer.PIXEL_FORMAT_RGBA,
		\"target_fps_min\": 30,
		\"target_fps_max\": 30,
	}
}))
	var stream_00_b : CamBANGStream = device_00.create_stream()

	
	stream_00.start()
	#stream_00_b.start()

	while not stream_00.result_live:
		await stream_00.result_live_changed
		
	var stream_result := stream_00.get_result()
	if stream_result == null:
		push_error(\"KERR stream result unexpectedly null after result_live\")
		return

	%StreamDisplayTexture.texture = stream_result.get_display_view()
	
	await get_tree().create_timer(50.0).timeout
	print(\"HERE I AM FUCKER\")
	stream_00.stop()
	stream_00.destroy()
	#stream_00_b.destroy()
	#CamBANGServer.stop()
	%StreamDisplayTexture.texture = null
	var huh = device_00.disengage()
	print(\"Huh?: %s\" % huh)


func _process(delta: float) -> void:
	pass


func _do_capture():
	var tmp = device_00.trigger_capture()
	print(\"tmp %s\" % tmp)
	while device_00.get_result() == null:
		#print(\"waiting\")
		await get_tree().process_frame
	#print(\"stopped waiting\")
	var capture_result : CamBANGCaptureResult = device_00.get_result()
	#var stream_result : CamBANGStreamResult = stream_00.get_result()
	%CaptureDisplayTexture.texture = ImageTexture.create_from_image(capture_result.to_image())
	print(\"KERR: GEO %s\" % capture_result.get_geolocation())
	print(\"KERR: OPTICAL CALIBRATION %s\" % capture_result.get_image_properties())

	var member: Dictionary = capture_result.get_image_member(0)
	
	if member.has(\"camera_facts\"):
		var p: Dictionary
		var d: Dictionary
		var k: Dictionary
		
		var facts: Dictionary = member[\"camera_facts\"]
		if facts.has(\"intrinsics\"):
			k = facts[\"intrinsics\"]
		# \"focal_length_x_px\", \"focal_length_y_px\",
		# \"principal_point_x_px\", \"principal_point_y_px\",
		# optional \"skew_px\", \"reference_width_px\", \"reference_height_px\",
		# coordinate-domain keys, and \"origin\" (who supplied it)
		if facts.has(\"distortion\"):
			d = facts[\"distortion\"]
		# e.g. \"model\": \"brown_conrady_5\", radial_k1..k3, tangential_p1/p2,
		# reference geometry, \"origin\"
		if facts.has(\"pose\"):
			p = facts[\"pose\"]
		
		%CaptureInfoText.text = str(\"pose: \", p, \"\\nDistortion: \", d, \"\\nIntrinsics: \", k)
	
	%CaptureInfoText.text += str(\"\\nMembers: \", capture_result.get_image_count())
func _do_teardown():
	# some stuff
	await get_tree().create_timer(WAIT_BEFORE_QUIT).timeout
	get_tree().quit()

func _input(event: InputEvent) -> void:
	if event is InputEventKey and event.pressed and not event.echo:
		var key_event := event as InputEventKey
		if key_event.keycode == KEY_ESCAPE:
			%SceneInfoText.text += \"Esc pressed; quitting scene\\n\"
			_do_teardown()
	
"

