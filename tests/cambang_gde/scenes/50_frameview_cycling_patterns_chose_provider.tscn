[sub_resource type="GDScript" id="GDScript_pr61q"]
resource_name = "connect_snapshot_view"
script/source = "extends Node
func _ready():	
	CamBANGServer.state_published.connect(_on_state_published)
	print(\"Calling CamBANGServer.start()\")
	CamBANGServer.start()
	print(\"Returned from CamBANGServer.start()\")

func _on_state_published(gen, version, topology_ver):
	var snap = CamBANGServer.get_state_snapshot()
	#print(\"Frm: \", Engine.get_frames_drawn(), \"	published gen=\", gen, \" version=\", version, \" topo=\", topology_ver,
		  #\" schema=\", snap.get_schema_version(),
		  #\" snap_gen=\", snap.get_gen(),
		  #\" snap_topo=\", snap.get_topology_version(),
		  #\" ts=\", snap.get_timestamp_ns())
		
	var frm := Engine.get_frames_drawn()
	var phys := Engine.get_physics_frames()
	
	print(\"\")
	print(\"=== state_published @ Frm=%d Phys=%d gen=%d ver=%d topo=%d ===\" % [frm, phys, gen, version, topology_ver])

	if snap == null:
		print(\"snapshot: <NIL>\")
		return
	if typeof(snap) != TYPE_DICTIONARY:
		print(\"snapshot: unexpected type=%d value=%s\" % [typeof(snap), str(snap)])
		return

	var d: Dictionary = snap
	print(\"snapshot(header): schema=%s gen=%s ver=%s topo=%s ts_ns=%s\"
		% [str(d.get(\"schema_version\")), str(d.get(\"gen\")), str(d.get(\"version\")),
		   str(d.get(\"topology_version\")), str(d.get(\"timestamp_ns\"))])


func _input(event):
	var selection : String = \"\"
	if event.is_action_pressed(\"request_synthetic_provider\"):
		selection = \"synthetic\"
	if event.is_action_pressed(\"request_hardware_backed_provider\"):
		selection = \"platform_backed\"
		
	if selection:
		CamBANGServer.set_provider_mode(selection)
		#print(\"selection made: %s\" % [selection])
	if event.is_action_pressed(\"request_server_start\"):
		CamBANGServer.start()
		
	if event.is_action_pressed(\"request_server_stop\"):
		CamBANGServer.stop()
"

