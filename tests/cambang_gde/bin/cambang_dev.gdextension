[configuration]
entry_symbol = "cambang_gdextension_init"
compatibility_minimum = "4.5"
reloadable = true

[libraries]
windows.x86_64.debug = "res://bin/cambang.windows.template_debug.x86_64.dll"
windows.x86_64.release = "res://bin/cambang.windows.template_release.x86_64.dll"
android.template_debug.arm64 = "res://bin/libcambang.android.template_debug.arm64.so"
android.template_release.arm64 = "res://bin/libcambang.android.template_release.arm64.so"